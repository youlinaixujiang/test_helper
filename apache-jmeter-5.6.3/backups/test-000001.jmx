        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="JDBC Request1">
          <stringProp name="dataSource"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="query">SELECT EXISTS (SELECT 1 FROM public.gis_osm_buildings_extracted AS poly JOIN public.gis_osm_buildings_extracted_to_point AS pt ON ST_Within(pt.geom,poly.geom) WHERE pt.gid = 11580 AND poly.gid = 11580);</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="variableNames"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
        </JDBCSampler>
        <hashTree/>
        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="JDBC Request2">
          <stringProp name="dataSource"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="query">SELECT EXISTS (SELECT 1 FROM public.gis_osm_buildings_extracted_z AS poly JOIN public.gis_osm_buildings_extracted_to_point_z AS pt ON ST_Within(pt.geom_z,poly.geom_z) WHERE pt.gid = 11580 AND poly.gid = 11580);</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="variableNames"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
