          <stringProp name="dataSource"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="query">select count(1) from public.gis_osm_buildings_extracted_z where  ((geom_z &amp;&amp; public.ST_setSRID(public.ST_GeomFromEWKB(geom_z),4326)) = &apos;t&apos;)</stringProp>
