        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="TC-002-断言401/404">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">401</stringProp>
