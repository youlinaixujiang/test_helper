        <!-- TC-008: 注入攻击 -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="TC-008-注入攻击">
          <stringProp name="HTTPSampler.domain">121.40.104.18</stringProp>
          <stringProp name="HTTPSampler.port"></stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
